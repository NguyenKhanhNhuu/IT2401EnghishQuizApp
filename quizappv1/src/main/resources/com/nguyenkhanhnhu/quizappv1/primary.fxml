      <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="subject" text="English Quizz App" />
      
      <Button mnemonicParsing="false" onAction="#manageQuestions" prefHeight="55.0" prefWidth="147.0" styleClass="Button" stylesheets="@style.css" text="Quản lí câu hỏi" />
