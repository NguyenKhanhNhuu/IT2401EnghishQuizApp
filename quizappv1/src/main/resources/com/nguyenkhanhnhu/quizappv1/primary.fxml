      <Button layoutX="256.0" layoutY="278.0" mnemonicParsing="false" onAction="#exam" prefHeight="55.0" prefWidth="150.0" styleClass="Button" stylesheets="@style.css" text="Luyện thi" />
      
      <ComboBox fx:id="cbThemes" prefHeight="55.0" prefWidth="150.0" promptText="Chọn chủ đề" styleClass="Button" />
